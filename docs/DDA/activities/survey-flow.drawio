  <diagram name="Flujo encuesta" id="survey-flow-full">
    <mxGraphModel dx="1374" dy="740" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="3200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1;fontColor=#3D3A50;" value="Flujo de encuesta de cuidado en casa" vertex="1">
          <mxGeometry height="70" width="760" x="90" y="40" as="geometry" />
        </mxCell>
        <mxCell id="intro" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacing=14;fontSize=13;fillColor=#F4F0FB;strokeColor=#A78BDF;fontColor=#3D3A50;" value="&lt;b&gt;Intro&lt;/b&gt;&lt;br&gt;Hola, gracias por ayudarnos.&lt;br&gt;&lt;br&gt;&lt;b&gt;Mensaje:&lt;/b&gt;&lt;br&gt;Queremos saber cómo llevaste el cuidado de una persona.&lt;br&gt;&lt;br&gt;&lt;b&gt;Acción:&lt;/b&gt; Empezar" vertex="1">
          <mxGeometry height="165" width="430" x="120" y="150" as="geometry" />
        </mxCell>
        <mxCell id="p1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacing=14;fontSize=13;fillColor=#F4FBF7;strokeColor=#6BBE95;fontColor=#3D3A50;" value="&lt;b&gt;P1. Tipo de cuidado&lt;/b&gt;&lt;br&gt;¿El cuidado que llevaste fue personal o para alguien más?&lt;br&gt;&lt;br&gt;&lt;b&gt;Opciones:&lt;/b&gt;&lt;br&gt;- Es mi cuidado personal&lt;br&gt;- Cuidé a otra persona" vertex="1">
          <mxGeometry height="175" width="430" x="120" y="370" as="geometry" />
        </mxCell>
        <mxCell id="p3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacing=14;fontSize=13;fillColor=#F4FBF7;strokeColor=#6BBE95;fontColor=#3D3A50;" value="&lt;b&gt;P3. Organización actual&lt;/b&gt;&lt;br&gt;¿Cómo organizaste ese cuidado?&lt;br&gt;&lt;br&gt;&lt;b&gt;Opciones:&lt;/b&gt;&lt;br&gt;- Papel/agenda física&lt;br&gt;- Grupo de WhatsApp familiar&lt;br&gt;- Memoria, nada por escrito&lt;br&gt;- Ya uso una app&lt;br&gt;- Otro&amp;nbsp;" vertex="1">
          <mxGeometry height="225" width="430" x="120" y="610" as="geometry" />
        </mxCell>
        <mxCell id="p4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacing=14;fontSize=13;fillColor=#F4FBF7;strokeColor=#6BBE95;fontColor=#3D3A50;" value="&lt;b&gt;P4. Mayor reto&lt;/b&gt;&lt;br&gt;¿Cuál fue tu mayor reto al cuidarlo/a?&lt;br&gt;&lt;br&gt;&lt;b&gt;Opciones:&lt;/b&gt;&lt;br&gt;- Recordar horarios de medicamentos&lt;br&gt;- Coordinar citas médicas&lt;br&gt;- Compartir información con familiares&lt;br&gt;- Falta de tiempo&lt;br&gt;- Costos del cuidado&lt;br&gt;- Otro&amp;nbsp;" vertex="1">
          <mxGeometry height="260" width="430" x="120" y="900" as="geometry" />
        </mxCell>
        <mxCell id="p5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacing=14;fontSize=13;fillColor=#F4FBF7;strokeColor=#6BBE95;fontColor=#3D3A50;" value="&lt;b&gt;P5. Incidente por organización&lt;/b&gt;&lt;br&gt;¿Tuviste algún incidente por falta de organización?&lt;br&gt;&lt;br&gt;&lt;b&gt;Opciones:&lt;/b&gt;&lt;br&gt;-&amp;nbsp; Sí&lt;br&gt;- No" vertex="1">
          <mxGeometry height="170" width="430" x="120" y="1230" as="geometry" />
        </mxCell>
        <mxCell id="p5story" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacing=14;fontSize=13;fillColor=#F4FBF7;strokeColor=#6BBE95;fontColor=#3D3A50;" value="&lt;b&gt;P5.1. Historia del incidente&lt;/b&gt;&lt;br&gt;Contanos brevemente qué pasó.&lt;br&gt;&lt;br&gt;&lt;b&gt;Tipo:&lt;/b&gt; texto abierto opcional&lt;br&gt;&lt;b&gt;Placeholder:&lt;/b&gt; Medicamento olvidado, cita perdida, confusión con horarios..." vertex="1">
          <mxGeometry height="170" width="430" x="700" y="1230" as="geometry" />
        </mxCell>
        <mxCell id="p6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacing=14;fontSize=13;fillColor=#F7F2FF;strokeColor=#A78BDF;fontColor=#3D3A50;" value="&lt;b&gt;P6. Confianza en app&lt;/b&gt;&lt;br&gt;¿Habrías confiado en una aplicación para llevar el control del cuidado?&lt;br&gt;&lt;br&gt;&lt;b&gt;Contexto:&lt;/b&gt; Medicamentos, citas, contactos de emergencia.&lt;br&gt;&lt;b&gt;Opciones:&lt;/b&gt;&lt;br&gt;- Sí&lt;br&gt;- No&lt;br&gt;- Tal vez" vertex="1">
          <mxGeometry height="215" width="430" x="120" y="1510" as="geometry" />
        </mxCell>
        <mxCell id="p7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacing=14;fontSize=13;fillColor=#F7F2FF;strokeColor=#A78BDF;fontColor=#3D3A50;" value="&lt;b&gt;P7. Razones para no confiar&lt;/b&gt;&lt;br&gt;¿Por qué no habrías confiado del todo?&lt;br&gt;&lt;br&gt;&lt;b&gt;Opciones:&lt;/b&gt;&lt;br&gt;- Prefiero papel/tradicional&lt;br&gt;- Privacidad de datos médicos&lt;br&gt;- No confío sin internet&lt;br&gt;- Información delicada para depender de una app&lt;br&gt;- Otro" vertex="1">
          <mxGeometry height="245" width="430" x="700" y="1490" as="geometry" />
        </mxCell>
        <mxCell id="p8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacing=14;fontSize=13;fillColor=#FFF4ED;strokeColor=#F09B6E;fontColor=#3D3A50;" value="&lt;b&gt;P8. Interés en usar app&lt;/b&gt;&lt;br&gt;¿Te habría gustado usar una app que te ayudara a gestionar esto?&lt;br&gt;&lt;br&gt;&lt;b&gt;Opciones:&lt;/b&gt;&lt;br&gt;- Sí&lt;br&gt;- No&lt;br&gt;- Tal vez" vertex="1">
          <mxGeometry height="185" width="430" x="120" y="1820" as="geometry" />
        </mxCell>
        <mxCell id="p8reason" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacing=14;fontSize=13;fillColor=#FFF4ED;strokeColor=#F09B6E;fontColor=#3D3A50;" value="&lt;b&gt;P8.1. Razón para no usarla&lt;/b&gt;&lt;br&gt;¿Por qué no o por qué no estabas seguro/a?&lt;br&gt;&lt;br&gt;&lt;b&gt;Tipo:&lt;/b&gt; texto abierto corto, obligatorio&lt;br&gt;&lt;b&gt;Resultado:&lt;/b&gt; envía encuesta y no muestra P9 ni precios" vertex="1">
          <mxGeometry height="190" width="430" x="700" y="1815" as="geometry" />
        </mxCell>
        <mxCell id="p9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacing=14;fontSize=13;fillColor=#FFF4ED;strokeColor=#F09B6E;fontColor=#3D3A50;" value="&lt;b&gt;P9. Función indispensable&lt;/b&gt;&lt;br&gt;¿Qué función te habría parecido indispensable?&lt;br&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;div&gt;&lt;b&gt;Opciones:&lt;/b&gt;&lt;br&gt;- Recordatorios de medicamentos&lt;br&gt;- Calendario de citas médicas&lt;br&gt;- Registro/historial de recetas&lt;br&gt;- Compartir información con familiares&lt;br&gt;- Contactos de emergencia&lt;br&gt;- Reportes para el médico&lt;br&gt;- Otro&lt;/div&gt;" vertex="1">
          <mxGeometry height="285" width="430" x="120" y="2110" as="geometry" />
        </mxCell>
        <mxCell id="p10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacing=14;fontSize=13;fillColor=#EFF8FF;strokeColor=#68A9D8;fontColor=#3D3A50;" value="&lt;b&gt;P10. Precio demasiado caro&lt;/b&gt;&lt;br&gt;¿Desde qué precio mensual te habría parecido demasiado cara?&lt;br&gt;&lt;br&gt;&lt;b&gt;Entrada:&lt;/b&gt; número entero en GTQ con prefijo Q" vertex="1">
          <mxGeometry height="150" width="430" x="120" y="2490" as="geometry" />
        </mxCell>
        <mxCell id="p11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacing=14;fontSize=13;fillColor=#EFF8FF;strokeColor=#68A9D8;fontColor=#3D3A50;" value="&lt;b&gt;P11. Cara pero pagable&lt;/b&gt;&lt;br&gt;¿Desde qué precio mensual habrías dicho que era cara, pero aún la pagarías si te convencía?&lt;br&gt;&lt;br&gt;&lt;b&gt;Entrada:&lt;/b&gt; número entero en GTQ con prefijo Q" vertex="1">
          <mxGeometry height="165" width="430" x="120" y="2710" as="geometry" />
        </mxCell>
        <mxCell id="p12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;align=left;verticalAlign=top;spacing=14;fontSize=13;fillColor=#EFF8FF;strokeColor=#68A9D8;fontColor=#3D3A50;" value="&lt;b&gt;P12. Muy accesible&lt;/b&gt;&lt;br&gt;¿Desde qué precio mensual habrías dicho que era muy accesible?&lt;br&gt;&lt;br&gt;&lt;b&gt;Entrada:&lt;/b&gt; número entero en GTQ con prefijo Q" vertex="1">
          <mxGeometry height="150" width="430" x="740" y="2340" as="geometry" />
